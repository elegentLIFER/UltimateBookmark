{
  "manifest_version": 3,
  "name": "Ultimate Bookmark",
  "version": "1.0.2",
  "description": "A sleek bookmark management browser extension.",
  "action": {
    "default_title": "Ultimate Bookmark"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["bookmarks", "tabs"],
  "minimum_chrome_version": "114"
}
